# ═══════════════════════════════════════════════
#  VPS Server Monitor — Configuration
# ═══════════════════════════════════════════════

telegram:
  bot_token: "YOUR_BOT_TOKEN_HERE"      # Get from @BotFather
  chat_id: "YOUR_CHAT_ID_HERE"          # Your Telegram chat ID

# Monitoring interval in minutes
check_interval_minutes: 10

# Alert thresholds (percentage) — alerts fire when exceeded
thresholds:
  cpu_percent: 80
  ram_percent: 80
  disk_percent: 85

# Send a full status summary every cycle (true) or only alerts (false)
send_summary: true

# ── Server List ─────────────────────────────
# Each server needs: name, host, user
# Auth: provide either 'password' or 'key_path' (SSH key)
# Port defaults to 22 if omitted
servers:
  - name: "Production VPS"
    host: "1.2.3.4"
    port: 22
    user: "root"
    password: "YOUR_PASSWORD"
    # key_path: "/path/to/key.pem"

  # - name: "Staging VPS"
  #   host: "5.6.7.8"
  #   port: 22
  #   user: "root"
  #   key_path: "~/.ssh/id_rsa"

  # - name: "Dev Server"
  #   host: "9.10.11.12"
  #   port: 2222
  #   user: "admin"
  #   password: "secret"
