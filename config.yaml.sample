# ═══════════════════════════════════════════════
#  Integrated VPS & Website Monitor — Configuration
# ═══════════════════════════════════════════════

telegram:
  bot_token: "YOUR_BOT_TOKEN_HERE"
  chat_id: "YOUR_CHAT_ID_HERE"
# Monitoring interval in minutes
check_interval_minutes: 10

# Alert thresholds (percentage)
thresholds:
  cpu_percent: 80
  ram_percent: 80
  disk_percent: 85
  # Include top processes in alerts if CPU or RAM thresholds are exceeded
  report_top_processes: true
  top_processes_count: 5

# Send a full status summary every cycle
send_summary: false

# ── Server List ──
servers:
  - name: "Production VPS"
    host: "1.2.3.4"
    port: 22
    user: "root"
    password: "YOUR_PASSWORD"
    # Or use key_path: "/path/to/key.pem"

# ── Website List ──
# Add any number of websites here
  websites:
  # Add more websites here
  - "https://example.com"

monitoring:
  # Optional: Specific timeout for website checks if different from default
  website_timeout: 10
