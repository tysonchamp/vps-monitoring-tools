# ═══════════════════════════════════════════════
#  Integrated VPS & Website Monitor — Configuration
# ═══════════════════════════════════════════════

telegram:
  bot_token: "YOUR_BOT_TOKEN_HERE"
  chat_id: "YOUR_CHAT_ID_HERE"
# Monitoring interval in minutes
check_interval_minutes: 10

# Alert thresholds (percentage)
thresholds:
  cpu_percent: 80
  ram_percent: 80
  disk_percent: 85

# Send a full status summary every cycle
send_summary: true

# ── Server List ──
servers:
  - name: "Production VPS"
    host: "1.2.3.4"
    port: 22
    user: "root"
    password: "YOUR_PASSWORD"
    # Or use key_path: "/path/to/key.pem"

# ── Website List ──
# Add any number of websites here
  websites:
  - url: "https://www.google.com"
    site_name: "Google"

  - url: "https://www.github.com"
    site_name: "GitHub"

  - url: "https://your-website.com"
    site_name: "My Main Website"

  # Example of a failing site for testing alerts
  # - url: "https://httpbin.org/status/404"
  #   site_name: "404 Test Site"

monitoring:
  # Optional: Specific timeout for website checks if different from default
  website_timeout: 10
